# ==============================
# 🔑 OPENROUTER CONFIG
# ==============================
OPENROUTER_API_KEY=your_api_key_here

# Example models:
# openai/gpt-3.5-turbo
# openai/gpt-4o-mini
# mistralai/mistral-7b-instruct

AI_MODEL=arcee-ai/trinity-large-preview:free


# ==============================
# 🤖 AI SETTINGS
# ==============================

# Enable / Disable AI replies
AI_ENABLED=true

# Your AI name (shown in terminal)
AI_NAME=Codevix AI


# ==============================
# ⚙️ OPTIONAL SETTINGS
# ==============================

# Reply delay (ms) - human-like feel
MIN_REPLY_DELAY=1000
MAX_REPLY_DELAY=3000